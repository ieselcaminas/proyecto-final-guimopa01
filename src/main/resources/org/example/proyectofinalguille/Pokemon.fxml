<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="495.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyectofinalguille.controller.PokemonController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <HBox prefHeight="55.0" prefWidth="455.0">
            <children>
                <Label contentDisplay="CENTER" prefHeight="43.0" prefWidth="70.0" text="Nombre">
                    <HBox.margin>
                        <Insets left="50.0" />
                    </HBox.margin></Label>
                <TextField fx:id="nomPoke" prefHeight="25.0" prefWidth="190.0" promptText="Pikachu">
                    <opaqueInsets>
                        <Insets />
                    </opaqueInsets>
                    <HBox.margin>
                        <Insets left="30.0" top="10.0" />
                    </HBox.margin></TextField>
            </children>
        </HBox>
        <HBox prefHeight="32.0" prefWidth="455.0">
            <children>
                <Label prefHeight="33.0" prefWidth="91.0" text="Tipo 1">
                    <HBox.margin>
                        <Insets left="50.0" />
                    </HBox.margin></Label>
                <ChoiceBox fx:id="Tipo1" prefWidth="150.0">
                    <opaqueInsets>
                        <Insets />
                    </opaqueInsets>
                    <HBox.margin>
                        <Insets left="30.0" />
                    </HBox.margin></ChoiceBox>
            </children>
        </HBox>
        <HBox layoutX="30.0" layoutY="258.0" prefHeight="33.0" prefWidth="455.0">
            <children>
                <Label prefHeight="33.0" prefWidth="91.0" text="Tipo 2">
                    <HBox.margin>
                        <Insets left="50.0" />
                    </HBox.margin></Label>
                <ChoiceBox fx:id="Tipo2" prefWidth="150.0">
                    <HBox.margin>
                        <Insets left="30.0" />
                    </HBox.margin></ChoiceBox>
            </children>
        </HBox>
        <HBox prefHeight="39.0" prefWidth="455.0">
            <children>
                <Button mnemonicParsing="false" onAction="#onAddPoke2" text="Añadir Pokemon">
                    <HBox.margin>
                        <Insets left="20.0" />
                    </HBox.margin></Button>
                <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#onAddTipo" text="Añadir Tipo">
                    <HBox.margin>
                        <Insets left="20.0" />
                    </HBox.margin></Button>
                <Button layoutX="70.0" layoutY="10.0" mnemonicParsing="false" onAction="#onDelPoke" text="Eliminar Pokemon">
                    <HBox.margin>
                        <Insets left="20.0" />
                    </HBox.margin></Button>
            </children>
        </HBox>
      <ListView fx:id="lista2" prefHeight="200.0" prefWidth="200.0" />
    </children>
</VBox>
