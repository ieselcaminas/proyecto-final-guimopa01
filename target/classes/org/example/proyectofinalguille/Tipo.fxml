<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="351.0" prefWidth="495.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyectofinalguille.controller.TipoController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <HBox prefHeight="55.0" prefWidth="455.0">
            <children>
                <Label contentDisplay="CENTER" prefHeight="43.0" prefWidth="70.0" text="Tipo">
                    <HBox.margin>
                        <Insets left="50.0" />
                    </HBox.margin></Label>
                <TextField fx:id="nomType" prefHeight="25.0" prefWidth="190.0" promptText="Null">
                    <opaqueInsets>
                        <Insets />
                    </opaqueInsets>
                    <HBox.margin>
                        <Insets left="30.0" top="10.0" />
                    </HBox.margin></TextField>
            </children>
        </HBox>
        <HBox prefHeight="56.0" prefWidth="455.0">
            <children>
                <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#onAddTipo2" text="Añadir Tipo">
                    <HBox.margin>
                        <Insets left="130.0" />
                    </HBox.margin></Button>
                <Button layoutX="70.0" layoutY="10.0" mnemonicParsing="false" onAction="#onDelTipo" text="Eliminar Tipo">
                    <HBox.margin>
                        <Insets left="20.0" />
                    </HBox.margin></Button>
            </children>
        </HBox>
      <ListView fx:id="lista3" onMouseClicked="#onSelecTipo" prefHeight="200.0" prefWidth="200.0" />
    </children>
</VBox>
